# Neovim-inspired Ghostty configuration

# Font configuration
font-family = JetBrains Mono Nerd Font
font-size = 12
font-feature = calt
font-feature = liga
font-feature = zero
font-style = Regular
# Removed invalid font-weight

# Padding and window
window-padding-x = 10
window-padding-y = 10
window-theme = dark
window-decoration = false
window-save-state = always
# Changed from "true" to "always"
# Removed invalid scrollback

# Cursor
cursor-style = block
# Removed invalid cursor-blink

# Selection
selection-background = #283457
selection-foreground = #c0caf5
mouse-hide-while-typing = true

# Cursor
cursor-color = #bb9af7
# Removed invalid pointer-color

# Border and opacity
unfocused-split-opacity = 0.9
confirm-close-surface = false
# Removed invalid title-in-tab-bar

# Normal colors
palette = 0=#15161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5=#bb9af7
palette = 6=#7dcfff
palette = 7=#a9b1d6

# Bright colors
palette = 8=#414868
palette = 9=#f7768e
palette = 10=#9ece6a
palette = 11=#e0af68
palette = 12=#7aa2f7
palette = 13=#bb9af7
palette = 14=#7dcfff
palette = 15=#c0caf5

# Background and foreground
background = #1a1b26
foreground = #c0caf5

# Shell integration - Changed from "true" to proper value
shell-integration = detect
shell-integration-features = cursor

# Misc settings
background-opacity = 0.95
# Added proper opacity setting
clipboard-paste-protection = false
clipboard-trim-trailing-spaces = true
copy-on-select = true
